# ESP-IDF 项目 gitignore 文件

# 构建输出目录
build/
**/build/

# SDKConfig 生成的配置文件（只保留 sdkconfig.defaults）
sdkconfig
**/sdkconfig
sdkconfig.old
**/sdkconfig.old

# ESP-IDF 特定文件
*.bin
*.elf
*.map
*.log

# 调试文件
.gdb_history
coredump*

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp

# Python 虚拟环境（如果有）
venv/
__pycache__/
*.pyc
